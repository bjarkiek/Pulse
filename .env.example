# Local development uses a process-local seeded repository when this is omitted.
AZURE_SQL_CONNECTION_STRING=

# Production App Service uses its managed identity with these settings instead
# of a password-bearing connection string.
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=Pulse

# Omit to use the authenticated local upload endpoint. In Azure, grant the app
# identity Storage Blob Data Contributor on this account.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER=pulse-attachments

# Required by the malware-scanning integration callback in production.
ATTACHMENT_SCAN_WEBHOOK_SECRET=

# Azure Communication Services Email (managed identity authentication).
AZURE_COMMUNICATION_EMAIL_ENDPOINT=
AZURE_COMMUNICATION_EMAIL_SENDER=
PULSE_PUBLIC_URL=http://localhost:3000
NOTIFICATION_JOB_SECRET=
WEBHOOK_SIGNING_SECRET=

# Never enable demo identity in production.
PULSE_ALLOW_DEMO_IDENTITY=false

# App-level auth (replaces App Service Easy Auth)
PULSE_SESSION_SECRET=
AUTH_ENTRA_TENANT_ID=
AUTH_ENTRA_CLIENT_ID=
AUTH_ENTRA_CLIENT_SECRET=
# DataCentral embed integration
DC_APP_SECRET=
DC_ALLOWED_PARENT_ORIGINS=https://app.datacentral.ai
DC_API_BASE_URL=
DC_SESSION_CHECK=when-available
DC_FRAME_ANCESTORS='self' https://*.datacentral.ai
PULSE_TRUST_EASYAUTH_HEADERS=false
# Enables per-request X-DC-Data/X-DC-Sig header auth (off by default; only enable if an
# API client authenticates via forwarded DataCentral launch headers).
# PULSE_TRUST_DC_HEADERS=false

# AI assistant (in-app chat panel + optional Slack bot). Omit ANTHROPIC_API_KEY to
# leave the assistant unconfigured; omit both SLACK_* values to leave Slack unconfigured.
# See docs/slack-setup.md for the Slack app manifest and token walkthrough.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
