# Local development uses a process-local seeded repository when this is omitted.
AZURE_SQL_CONNECTION_STRING=

# Production App Service uses its managed identity with these settings instead
# of a password-bearing connection string.
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=Pulse

# Omit to use the authenticated local upload endpoint. In Azure, grant the app
# identity Storage Blob Data Contributor on this account.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER=pulse-attachments

# Required by the malware-scanning integration callback in production.
ATTACHMENT_SCAN_WEBHOOK_SECRET=

# Azure Communication Services Email (managed identity authentication).
AZURE_COMMUNICATION_EMAIL_ENDPOINT=
AZURE_COMMUNICATION_EMAIL_SENDER=
PULSE_PUBLIC_URL=http://localhost:3000
NOTIFICATION_JOB_SECRET=
WEBHOOK_SIGNING_SECRET=

# Never enable demo identity in production.
PULSE_ALLOW_DEMO_IDENTITY=false
