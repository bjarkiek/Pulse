{
  "name": "datacentral-ideas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "next dev",
    "build": "next build",
    "build:sites": "bash scripts/build-verified.sh",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --import tsx --test --test-concurrency=1 tests/domain.test.mjs tests/openapi.test.mjs tests/workflow.test.ts tests/dc-auth.test.ts tests/chat.test.ts",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "eslint app lib --ignore-pattern .next",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@azure/communication-email": "^1.1.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.33.0",
    "drizzle-orm": "0.45.2",
    "jose": "^6.2.3",
    "mssql": "^12.7.0",
    "next": "16.2.6",
    "openid-client": "^6.8.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/mssql": "^9.1.11",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "displayName": "DataCentral Pulse"
}
